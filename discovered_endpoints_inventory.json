  "websocket_streams": {
    "description": "Real-time WebSocket streams (Socket.IO over WebSocket transport)",
    "server": "quotes-api.tickertape.in",
    "transports": [
      "websocket",
      "polling"
    ],
    "discovered_namespaces": [
      "/quotes?sids=${e.join(\",\")}",
      "/quotes?sids=${e}"
    ],
    "context": [],
    "route_socketio_mappings": {
      "description": "Socket.IO paths in the app correspond to data namespaces",
      "paths": [
        "/stocks",
        "/screener",
        "/portfolio",
        "/mutualfunds",
        "/indices",
        "/etfs",
        "/pricing",
        "/market-mood-index",
        "/us-stocks",
        "/profile",
        "/space",
        "/social-pricing"
      ]
    }
  },
